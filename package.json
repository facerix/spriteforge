{
  "name": "spriteforge",
  "version": "0.0.1",
  "description": "Web app for working with animated images and sprite sheets",
  "main": "index.html",
  "scripts": {
    "vendor": "node scripts/vendor.mjs",
    "postinstall": "node scripts/vendor.mjs",
    "start": "live-server --no-browser",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy:changed": "bash scripts/deploy-changed.sh"
  },
  "author": "Rylee Corradini",
  "license": "GPL-3.0",
  "devDependencies": {
    "gifenc": "1.0.3",
    "upng-js": "2.1.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "live-server": "^1.2.2",
    "prettier": "^3.0.0"
  }
}
